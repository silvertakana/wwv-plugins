{
    "name": "@worldwideview/wwv-plugin-wildfire",
    "version": "1.1.1",
    "description": "WorldWideView plugin for active wildfire and hotspot detection using NASA FIRMS (VIIRS) satellite data. Supports tiered LOD rendering and FRP-based sizing",
    "main": "dist/frontend.mjs",
    "types": "src/index.ts",
    "files": [
        "src"
    ],
    "keywords": [
        "worldwideview",
        "worldwideview-plugin",
        "wwv-plugin-wildfire",
        "wildfire",
        "fire-detection",
        "nasa-firms",
        "viirs",
        "satellite",
        "cesium",
        "globe"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/silvertakana/worldwideview-plugins.git",
        "directory": "packages/wwv-plugin-wildfire"
    },
    "homepage": "https://github.com/silvertakana/worldwideview#readme",
    "bugs": {
        "url": "https://github.com/silvertakana/worldwideview/issues"
    },
    "license": "ISC",
    "author": "WorldWideView",
    "peerDependencies": {
        "@worldwideview/wwv-plugin-sdk": "workspace:*",
        "lucide-react": ">=0.576.0"
    },
    "worldwideview": {
        "id": "wildfire",
        "icon": "Flame",
        "category": "Natural Disaster",
        "format": "bundle",
        "capabilities": [
            "layer"
        ]
    },
    "type": "module",
    "module": "dist/frontend.mjs",
    "scripts": {
        "build": "vite build"
    }
}
