{
  "name": "@worldwideview/wwv-plugin-rocket-launches",
  "version": "1.1.0",
  "description": "Upcoming and recent rocket launches from Launch Library 2, pinned to launch sites worldwide.",
  "type": "module",
  "main": "dist/frontend.mjs",
  "module": "dist/frontend.mjs",
  "types": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "worldwideview",
    "worldwideview-plugin",
    "wwv-plugin-rocket-launches",
    "rocket",
    "launches",
    "space",
    "real-time",
    "cesium",
    "globe"
  ],
  "author": "WorldWideView",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/silvertakana/wwv-plugins.git",
    "directory": "wwv-plugin-rocket-launches"
  },
  "homepage": "https://github.com/silvertakana/worldwideview#readme",
  "bugs": {
    "url": "https://github.com/silvertakana/worldwideview/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "worldwideview": {
    "id": "rocket-launches",
    "type": "data-layer",
    "format": "bundle",
    "category": "space",
    "icon": "Rocket",
    "dev_entry": "src/index.ts",
    "capabilities": [
      "data:own",
      "globe:overlay",
      "network:fetch"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@worldwideview/wwv-plugin-sdk": "*"
  },
  "dependencies": {
    "lucide-react": "^0.470.0"
  },
  "devDependencies": {
    "@worldwideview/wwv-plugin-sdk": "workspace:*",
    "@types/react": "^19.0.0",
    "rollup-plugin-external-globals": "^0.10.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7",
    "typescript": "^5.5.0"
  }
}
